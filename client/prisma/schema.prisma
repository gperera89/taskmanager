// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Selectable options for Task.category (a free-text field on Task itself — this table only
// drives the "pick or manage a category" UI, it isn't a foreign key).
model Category {
  id   String @id @default(uuid())
  name String @unique
  // Which top-bar mode (work/home) tasks in this category belong to. NONE means "both": the
  // task stays visible in every mode rather than silently vanishing outside "all" (the old
  // behavior matched only the literal names "Work"/"Home").
  scope CategoryScope @default(NONE)
}

enum CategoryScope {
  WORK
  HOME
  NONE
}

// Single-row app-wide settings (this is a single-user app). Lazily created on first read (see
// api.ts's getAppSettings) — the fixed id just gives the singleton row something to key on.
model AppSettings {
  id       String @id @default("app")
  // IANA zone name used to interpret due/reminder clock times and display calendar events.
  timeZone String @default("Asia/Shanghai")
  // Stamped by /api/cron/check-due on every run — the notification system's heartbeat. The UI
  // warns when this goes stale, making a lapsed external scheduler visible instead of silent.
  lastCronAt DateTime?
}

// One row per dismissed calendar (ICS) event instance, so a dismissal survives across
// devices/browsers. `eventId` mirrors CalendarEvent.id (source-uid-startISO), so a recurring
// event's individual occurrences are dismissed independently rather than as a whole series.
model DismissedCalendarEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  dismissedAt DateTime @default(now())
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  // Set once a due-date push notification has been sent for this dueDate, so the notification
  // cron never re-sends for the same deadline. Cleared implicitly whenever dueDate changes.
  notifiedAt  DateTime?
  // Notify this many minutes before the due instant instead of at it (null = at the due time).
  reminderLeadMinutes Int?
  // How long this is expected to take, in minutes (null = unset). Lets a dated item occupy a
  // block of time on the schedule rather than a single instant.
  durationMinutes Int?
  // Whether this project's card offers Things-style section headings (the "Create sections" /
  // "Remove sections" button on the card). Turning it off clears every task's section value.
  sectionsEnabled Boolean @default(false)
  tasks       Task[]
}

// An important date to count down to, shown in the calendar rail ("12 days · Tracey's
// birthday"). `date` uses the UTC-midnight calendar-date encoding. Yearly countdowns target the
// next anniversary of `date` — the stored year is the original occurrence's (birth year, wedding
// year), so labels can carry the elapsed years ("42 years"). One-off countdowns target the date
// itself and disappear once it has passed (swept by the notification cron).
model Countdown {
  id            String   @id @default(uuid())
  title         String
  date          DateTime
  repeatsYearly Boolean  @default(true)
  createdAt     DateTime @default(now())
  // The occurrence (UTC-midnight date) each push kind was last sent for, so the cron sends the
  // week-before heads-up and the on-the-day push exactly once per occurrence. Cleared on edit.
  notifiedHeadsUpFor DateTime?
  notifiedOnDayFor   DateTime?
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  // When isCompleted last flipped true — cleared on un-complete. Drives the 30-day archive
  // window (getTasks) and the Logbook; older completed tasks stop being fetched entirely.
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  // Set once a due-date push notification has been sent for this dueDate, so the notification
  // cron never re-sends for the same deadline. Cleared implicitly whenever dueDate changes.
  notifiedAt  DateTime?
  // Notify this many minutes before the due instant instead of at it (null = at the due time).
  reminderLeadMinutes Int?
  // How long this task is expected to take, in minutes (null = unset). Lets a dated task occupy
  // a block of time on the schedule rather than a single instant.
  durationMinutes Int?
  // On-hold marker: what this task is waiting on before it can proceed (null = not blocked),
  // and the date the block is expected to clear (UTC-midnight calendar-date encoding). While
  // blocked, the task is excluded from My Day auto-scheduling/look-ahead; the AI planner is
  // told about blocks so it can nudge when one expires or a deadline looms behind it.
  blockedReason String?
  blockedUntil  DateTime?
  // Optional grouping heading within a project's card (Things-style sections). Free text,
  // meaningful only for tasks with a projectId.
  section     String?
  // Manual ordering within a due bucket / project section (fractional indexing — reorders
  // assign midpoints, occasional bulk rewrites renumber a whole group). Null = no manual
  // position: sorts after ordered tasks, by due time then creation.
  sortOrder   Float?

  // Repeating tasks: null repeatFrequency means the task doesn't repeat. Unlike Routines
  // (which just track "is today active"), a repeating Task has one concrete dueDate that gets
  // rolled forward to the next occurrence in place when it's completed — no history rows.
  repeatFrequency      RoutineFrequency?
  repeatInterval       Int?
  repeatDaysOfWeek     Int[]               @default([])
  repeatMonthlyMode    RoutineMonthlyMode?
  repeatDayOfMonth     Int?
  repeatMonthlyOrdinal Int?
  repeatMonthlyWeekday Int?
  // End of a repeating series: once completing would roll the due date past this calendar date
  // (UTC-midnight encoding), the task is marked done instead of rolling forward. Null = forever.
  repeatUntil          DateTime?
  // Break/holiday marker for a repeating task (UTC-midnight encoding), mirroring
  // Routine.pausedUntil. While today is before this date the task is hidden from the due
  // buckets (shown "Paused until …") and its reminder is suppressed; it resumes on/after it.
  pausedUntil          DateTime?

  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])

  // Subtasks: a task can be broken down into child tasks of itself.
  parentId    String?
  parent      Task?     @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]    @relation("TaskSubtasks")
}

enum CapturedKind {
  TASK
  PROJECT
  ROUTINE
  HABIT
}

// One row per completion event — the app's history. Written when a task completes (including
// a repeating task rolling forward, which otherwise leaves no trace), a routine cluster ticks
// (auto = ticked by the notification cron rather than the user), or a habit is marked done.
// `title` is denormalized so history survives the entity being renamed or deleted.
model CompletionLog {
  id          String   @id @default(uuid())
  entityType  CapturedKind
  entityId    String
  title       String
  completedAt DateTime @default(now())
  auto        Boolean  @default(false)

  @@index([completedAt])
  @@index([entityType, entityId])
}

// How a capture notice was created — a spoken memo (Whisper + LLM) or an inbound email
// (LLM extraction). Drives the label shown in the notification panel.
enum CaptureSource {
  VOICE
  EMAIL
}

// A capture — either a voice memo transcribed by Whisper, or an inbound email — parsed by an
// LLM into a Task/Project/Routine/Habit, which is created immediately. This row is just the
// unread notice pointing at that entity — marking it read or opening it for editing deletes
// the row (see dismissVoiceCapture).
model VoiceCapture {
  id          String        @id @default(uuid())
  // The source text: the voice transcript, or the email subject/snippet.
  transcript  String
  kind        CapturedKind
  entityId    String
  summary     String
  source      CaptureSource @default(VOICE)
  // Set when the LLM's JSON response couldn't be parsed, so the transcript was filed as a
  // plain task instead of being understood. Surfaced in the UI as "needs review".
  parseError  Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

// How a habit is scheduled. Replaces the old "every N days/weeks/months" interval model.
enum HabitScheduleType {
  // On specific days of the week (Habit.daysOfWeek), e.g. weekdays + Saturday.
  WEEKLY_DAYS
  // A target number of times per calendar week, any days (Habit.targetCount).
  WEEKLY_COUNT
  // A target number of times per calendar month, any days (Habit.targetCount).
  MONTHLY_COUNT
}

model Habit {
  id                String            @id @default(uuid())
  title             String
  scheduleType      HabitScheduleType @default(WEEKLY_DAYS)
  // WEEKLY_COUNT / MONTHLY_COUNT: how many completions make up a full period.
  targetCount       Int               @default(1)
  // WEEKLY_DAYS: which days the habit is scheduled on; 0=Sunday..6=Saturday.
  daysOfWeek        Int[]             @default([])
  // How long each occurrence is expected to take, in minutes (null = unset).
  durationMinutes   Int?
  // Planned break (e.g. a holiday): an inclusive [pauseStart, pauseEnd] band of calendar dates
  // (UTC-midnight encoding). Scheduled days inside the band are shown greyed in the heatmap and
  // excluded from streak / at-risk math, so an intentional skip doesn't read as a lapse.
  pauseStart        DateTime?
  pauseEnd          DateTime?
  completions       HabitCompletion[]
}

// One row per completed calendar date (at most one per habit per day, enforced by the unique
// index). `date` uses the same UTC-midnight-of-the-calendar-date encoding as due dates (see
// combineDueDateTime in lib/shared.ts). Streaks and per-period progress are computed from these
// rows, so no cached streak counters live on Habit. This is the heatmap's data source and is
// editable by date (see toggleHabitCompletion).
model HabitCompletion {
  id        String   @id @default(uuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId, date])
}

// A per-day placement of an existing entity on the My Day timeline. Loose reference — entityId
// spans four tables depending on entityType (no FK), so the deriver skips blocks whose entity no
// longer exists and each entity's delete path clears its blocks. `date` uses the same
// UTC-midnight-of-the-calendar-date encoding as due dates. startTime is a face-value "HH:MM"
// (same convention as Routine.reminderTime): set = pinned at that time, null = floats (auto-
// scheduled by the client-side packer, or sits in the "needs a time" tray).
model DayPlanBlock {
  id              String       @id @default(uuid())
  date            DateTime
  entityType      CapturedKind
  entityId        String
  startTime       String?
  // Overrides the entity's own durationMinutes for this day only (null = inherit).
  durationMinutes Int?
  // Manual priority among floating blocks (fractional indexing, like Task.sortOrder).
  sortOrder       Float?
  createdAt       DateTime     @default(now())

  // One block per entity per day — "do today" and offline replays stay idempotent (upsert).
  @@unique([date, entityType, entityId])
  @@index([date])
}

// AI planner suggestions (My Day). Rows are never deleted — a responded row IS the feedback-log
// entry (kind/title/eventTitle denormalized like CompletionLog), and its dedupeKey permanently
// suppresses regeneration of the same idea (the DismissedCalendarEvent pattern).
enum SuggestionStatus {
  PENDING
  ACCEPTED
  SNOOZED
  DISMISSED
}

model AiSuggestion {
  id            String           @id @default(uuid())
  // "<kind>:<CalendarEvent.id>" for event-derived ideas, "<kind>:<date>:<slug>" for novel ones.
  dedupeKey     String           @unique
  // lesson-prep | interview-review | report | birthday | meeting-notes | novel | ...
  kind          String
  title         String
  description   String?
  // The calendar event that prompted this (CalendarEvent.id + denormalized title), if any.
  eventId       String?
  eventTitle    String?
  // Proposed due date for the created task — UTC-midnight calendar date encoding.
  suggestedDate DateTime?
  status        SuggestionStatus @default(PENDING)
  // SNOOZED rows flip back to PENDING when this date arrives (checked during generation).
  snoozedUntil  DateTime?
  // Loose ref to the Task created on accept (display only).
  createdTaskId String?
  createdAt     DateTime         @default(now())
  respondedAt   DateTime?

  @@index([status, createdAt])
}

// Free-text standing instructions for the AI planner ("notes for future consideration") —
// included verbatim in every generation prompt. Seeded with the user's workflow rules.
model AiNote {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
}

enum RoutineFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// MONTHLY routines recur either on a fixed date ("Each" — the 12th, or the last day) or on
// the Nth weekday of the month ("On the" — e.g. the first Wednesday).
enum RoutineMonthlyMode {
  DATE
  WEEKDAY
}

model Routine {
  id           String           @id @default(uuid())
  title        String
  reminderTime String
  frequency    RoutineFrequency @default(DAILY)
  // Recurs every `interval` `frequency` units, e.g. interval=2, frequency=WEEKLY = "every 2 weeks".
  interval     Int              @default(1)
  // Used when frequency = WEEKLY; 0=Sunday..6=Saturday. Supports multiple days per week.
  daysOfWeek   Int[]            @default([])
  // Used when frequency = MONTHLY.
  monthlyMode    RoutineMonthlyMode @default(DATE)
  // MONTHLY + monthlyMode=DATE: 1-31, or -1 to mean "the last day of the month".
  dayOfMonth     Int?
  // MONTHLY + monthlyMode=WEEKDAY: 1-5 for First..Fifth, -1 for "Last".
  monthlyOrdinal Int?
  // MONTHLY + monthlyMode=WEEKDAY: 0=Sunday..6=Saturday.
  monthlyWeekday Int?
  // How long this routine is expected to take, in minutes (null = unset).
  durationMinutes Int?
  isActive     Boolean          @default(true)
  // When it was last ticked; ticking auto-expires after 1 hour and resets on the next scheduled occurrence.
  lastCompletedAt DateTime?
  // Set once a push notification has gone out for today's scheduled occurrence, so the cron
  // doesn't resend until the calendar date rolls over. Only meaningful on top-level routines
  // (parentId = null) — sub-routines fire as part of their parent's single grouped notification.
  notifiedAt   DateTime?
  // Skip every scheduled occurrence strictly before this calendar date (e.g. a holiday break),
  // then resume normally on/after it. Date-only, same UTC-midnight encoding as Task/Project
  // dueDate. Only meaningful on top-level routines, like notifiedAt above.
  pausedUntil  DateTime?

  // Sub-routines group under a parent so the whole cluster fires as one notification and is
  // ticked off together (e.g. "Wake Up Routine" -> "Make coffee", "Brush teeth", "Shave").
  // A child has no schedule of its own — it always follows its parent's reminderTime/frequency.
  parentId    String?
  parent      Routine?  @relation("RoutineSubroutines", fields: [parentId], references: [id], onDelete: Cascade)
  subroutines Routine[] @relation("RoutineSubroutines")
}