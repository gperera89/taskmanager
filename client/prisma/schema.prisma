// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Selectable options for Task.category (a free-text field on Task itself — this table only
// drives the "pick or manage a category" UI, it isn't a foreign key).
model Category {
  id   String @id @default(uuid())
  name String @unique
  // Which top-bar mode (work/home) tasks in this category belong to. NONE means "both": the
  // task stays visible in every mode rather than silently vanishing outside "all" (the old
  // behavior matched only the literal names "Work"/"Home").
  scope CategoryScope @default(NONE)
}

enum CategoryScope {
  WORK
  HOME
  NONE
}

// Single-row app-wide settings (this is a single-user app). Lazily created on first read (see
// api.ts's getAppSettings) — the fixed id just gives the singleton row something to key on.
model AppSettings {
  id       String @id @default("app")
  // IANA zone name used to interpret due/reminder clock times and display calendar events.
  timeZone String @default("Asia/Shanghai")
  // Stamped by /api/cron/check-due on every run — the notification system's heartbeat. The UI
  // warns when this goes stale, making a lapsed external scheduler visible instead of silent.
  lastCronAt DateTime?
}

// One row per dismissed calendar (ICS) event instance, so a dismissal survives across
// devices/browsers. `eventId` mirrors CalendarEvent.id (source-uid-startISO), so a recurring
// event's individual occurrences are dismissed independently rather than as a whole series.
model DismissedCalendarEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  dismissedAt DateTime @default(now())
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  // Set once a due-date push notification has been sent for this dueDate, so the notification
  // cron never re-sends for the same deadline. Cleared implicitly whenever dueDate changes.
  notifiedAt  DateTime?
  // Notify this many minutes before the due instant instead of at it (null = at the due time).
  reminderLeadMinutes Int?
  tasks       Task[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  // When isCompleted last flipped true — cleared on un-complete. Drives the 30-day archive
  // window (getTasks) and the Logbook; older completed tasks stop being fetched entirely.
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  // Set once a due-date push notification has been sent for this dueDate, so the notification
  // cron never re-sends for the same deadline. Cleared implicitly whenever dueDate changes.
  notifiedAt  DateTime?
  // Notify this many minutes before the due instant instead of at it (null = at the due time).
  reminderLeadMinutes Int?
  // Optional grouping heading within a project's card (Things-style sections). Free text,
  // meaningful only for tasks with a projectId.
  section     String?
  // Manual ordering within a due bucket / project section (fractional indexing — reorders
  // assign midpoints, occasional bulk rewrites renumber a whole group). Null = no manual
  // position: sorts after ordered tasks, by due time then creation.
  sortOrder   Float?

  // Repeating tasks: null repeatFrequency means the task doesn't repeat. Unlike Routines
  // (which just track "is today active"), a repeating Task has one concrete dueDate that gets
  // rolled forward to the next occurrence in place when it's completed — no history rows.
  repeatFrequency      RoutineFrequency?
  repeatInterval       Int?
  repeatDaysOfWeek     Int[]               @default([])
  repeatMonthlyMode    RoutineMonthlyMode?
  repeatDayOfMonth     Int?
  repeatMonthlyOrdinal Int?
  repeatMonthlyWeekday Int?

  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])

  // Subtasks: a task can be broken down into child tasks of itself.
  parentId    String?
  parent      Task?     @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]    @relation("TaskSubtasks")
}

// A device's Web Push registration (one per browser/device the user has enabled notifications
// on — e.g. one for their phone, one for their desktop). endpoint uniquely identifies the
// device+browser's push channel with the browser vendor's push service.
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

enum CapturedKind {
  TASK
  PROJECT
  ROUTINE
  HABIT
}

// One row per completion event — the app's history. Written when a task completes (including
// a repeating task rolling forward, which otherwise leaves no trace), a routine cluster ticks
// (auto = ticked by the notification cron rather than the user), or a habit is marked done.
// `title` is denormalized so history survives the entity being renamed or deleted.
model CompletionLog {
  id          String   @id @default(uuid())
  entityType  CapturedKind
  entityId    String
  title       String
  completedAt DateTime @default(now())
  auto        Boolean  @default(false)

  @@index([completedAt])
  @@index([entityType, entityId])
}

// How a capture notice was created — a spoken memo (Whisper + LLM) or an inbound email
// (LLM extraction). Drives the label shown in the notification panel.
enum CaptureSource {
  VOICE
  EMAIL
}

// A capture — either a voice memo transcribed by Whisper, or an inbound email — parsed by an
// LLM into a Task/Project/Routine/Habit, which is created immediately. This row is just the
// unread notice pointing at that entity — marking it read or opening it for editing deletes
// the row (see dismissVoiceCapture).
model VoiceCapture {
  id          String        @id @default(uuid())
  // The source text: the voice transcript, or the email subject/snippet.
  transcript  String
  kind        CapturedKind
  entityId    String
  summary     String
  source      CaptureSource @default(VOICE)
  // Set when the LLM's JSON response couldn't be parsed, so the transcript was filed as a
  // plain task instead of being understood. Surfaced in the UI as "needs review".
  parseError  Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

enum HabitIntervalUnit {
  DAY
  WEEK
  MONTH
}

model Habit {
  id                String            @id @default(uuid())
  title             String
  // The habit repeats every `intervalValue` `intervalUnit`s, e.g. 1 DAY, 3 DAYS, 2 WEEKS,
  // 1 MONTH — a single number+unit pair covers what used to be five fixed frequency options.
  intervalValue     Int               @default(1)
  intervalUnit      HabitIntervalUnit @default(DAY)
  currentStreak     Int               @default(0)
  longestStreak     Int               @default(0)
  lastCompletedDate DateTime?
}

enum RoutineFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// MONTHLY routines recur either on a fixed date ("Each" — the 12th, or the last day) or on
// the Nth weekday of the month ("On the" — e.g. the first Wednesday).
enum RoutineMonthlyMode {
  DATE
  WEEKDAY
}

model Routine {
  id           String           @id @default(uuid())
  title        String
  reminderTime String
  frequency    RoutineFrequency @default(DAILY)
  // Recurs every `interval` `frequency` units, e.g. interval=2, frequency=WEEKLY = "every 2 weeks".
  interval     Int              @default(1)
  // Used when frequency = WEEKLY; 0=Sunday..6=Saturday. Supports multiple days per week.
  daysOfWeek   Int[]            @default([])
  // Used when frequency = MONTHLY.
  monthlyMode    RoutineMonthlyMode @default(DATE)
  // MONTHLY + monthlyMode=DATE: 1-31, or -1 to mean "the last day of the month".
  dayOfMonth     Int?
  // MONTHLY + monthlyMode=WEEKDAY: 1-5 for First..Fifth, -1 for "Last".
  monthlyOrdinal Int?
  // MONTHLY + monthlyMode=WEEKDAY: 0=Sunday..6=Saturday.
  monthlyWeekday Int?
  isActive     Boolean          @default(true)
  // When it was last ticked; ticking auto-expires after 1 hour and resets on the next scheduled occurrence.
  lastCompletedAt DateTime?
  // Set once a push notification has gone out for today's scheduled occurrence, so the cron
  // doesn't resend until the calendar date rolls over. Only meaningful on top-level routines
  // (parentId = null) — sub-routines fire as part of their parent's single grouped notification.
  notifiedAt   DateTime?
  // Skip every scheduled occurrence strictly before this calendar date (e.g. a holiday break),
  // then resume normally on/after it. Date-only, same UTC-midnight encoding as Task/Project
  // dueDate. Only meaningful on top-level routines, like notifiedAt above.
  pausedUntil  DateTime?

  // Sub-routines group under a parent so the whole cluster fires as one notification and is
  // ticked off together (e.g. "Wake Up Routine" -> "Make coffee", "Brush teeth", "Shave").
  // A child has no schedule of its own — it always follows its parent's reminderTime/frequency.
  parentId    String?
  parent      Routine?  @relation("RoutineSubroutines", fields: [parentId], references: [id], onDelete: Cascade)
  subroutines Routine[] @relation("RoutineSubroutines")
}